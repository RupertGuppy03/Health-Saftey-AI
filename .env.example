# Copy this file to `.env` and fill in your own values.
# The real `.env` file is gitignored — never commit it.

# --- OpenAI ---
OPENAI_API_KEY=

# Model used for generating answers
OPENAI_MODEL=gpt-4o

# Model used for creating embeddings
EMBEDDING_MODEL=text-embedding-3-small

# --- ChromaDB ---
# Where the vector store is saved on disk
CHROMA_PERSIST_DIR=./vectorstore

# --- Frontend -> backend ---
# The URL the Streamlit UI uses to reach the FastAPI backend
API_URL=http://localhost:8000
